# LLM Provider: "openai" (DeepSeek 兼容 OpenAI 接口) 或 "anthropic"
LLM_PROVIDER=openai

# Model name
# DeepSeek V4: deepseek-v4-flash (轻量快速), deepseek-v4-pro (旗舰推理)
# DeepSeek 旧版: deepseek-chat, deepseek-reasoner (2026-07-24 弃用)
# Anthropic: claude-haiku-3-5, claude-sonnet-4-6
# OpenAI: gpt-3.5-turbo, gpt-4o
LLM_MODEL=deepseek-v4-flash

# API Keys — 支持最多 3 个 key，玩家自动分配（每人一个 key，轮流分配）
# 9 名玩家配 3 个 key = 每 key 服务 3 人，避免限流
#
# 加密方式（AES-256-GCM）：
#   1. (推荐) 生成密钥文件: python crypto_utils.py keygen
#      会在 ~/.werewolf-key 创建一个随机密钥文件
#   2. 加密 API Key: python crypto_utils.py encrypt sk-your-key-here
#      把输出的 ENC2:... 值填在下面
#   3. 也可以直接填写明文 key（不推荐，但兼容）
#
# 旧格式 ENC:... (XOR) 仍然支持解密，但新加密请使用 ENC2:
LLM_API_KEY_1=ENC2:your-encrypted-key-1-here
LLM_API_KEY_2=ENC2:your-encrypted-key-2-here
LLM_API_KEY_3=ENC2:your-encrypted-key-3-here

# Custom API base URL
LLM_BASE_URL=https://api.deepseek.com

# Delay between phases in AI referee mode (seconds)
GAME_SPEED_DELAY=2.0

# Temperature for LLM responses (0~1)
LLM_TEMPERATURE=0.6

# Maximum tokens per LLM response
LLM_MAX_TOKENS=5000
